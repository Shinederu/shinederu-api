# --- APPLICATION AUTH ---
BASE_API=https://api.shinederu.ch/auth/
ALLOWED_MIME=image/png,image/jpeg,image/webp
SESSION_DURATION_HOURS=168

# --- DATABASE ---
DB_TYPE=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=ShinedeCore
DB_USER=authenticator
DB_PASS=change_me

# --- MERCURE / REALTIME ---
MERCURE_HUB_URL=https://mercure.shinederu.ch/.well-known/mercure
MERCURE_PUBLISH_URL=http://mercure/.well-known/mercure
MERCURE_PUBLISHER_JWT_KEY=change_me
MERCURE_SUBSCRIBER_JWT_KEY=change_me
MQ_MERCURE_TOPIC_BASE=https://api.shinederu.ch/melodyquest/topics
MQ_MERCURE_COOKIE_DOMAIN=.shinederu.ch
MQ_MERCURE_COOKIE_PATH=/.well-known/mercure
MQ_MERCURE_SUBSCRIBER_TTL_SECONDS=90

# --- MAIL ---
SMTP_HOST=mail.example.com
SMTP_AUTH=true
SMTP_USER=contact@example.com
SMTP_PASS=change_me
SMTP_PORT=465
SMTP_FROM=contact@example.com
SMTP_NAME="Shinederu Authentificator"
