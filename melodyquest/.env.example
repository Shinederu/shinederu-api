# MelodyQuest DB env vars (for PHP runtime)
MQ_DB_TYPE=mysql
MQ_DB_HOST=mysql-server
MQ_DB_NAME=ShinedeCore
MQ_DB_USER=MelodyQuestUser
MQ_DB_PASS=change_me
MQ_DB_PORT=3306

# Mercure hub (same runtime .env as auth)
MERCURE_HUB_URL=https://mercure.shinederu.ch/.well-known/mercure
MERCURE_PUBLISH_URL=http://mercure/.well-known/mercure
MERCURE_PUBLISHER_JWT_KEY=change_me
MERCURE_SUBSCRIBER_JWT_KEY=change_me
MQ_MERCURE_TOPIC_BASE=https://api.shinederu.ch/melodyquest/topics
MQ_MERCURE_COOKIE_DOMAIN=.shinederu.ch
MQ_MERCURE_COOKIE_PATH=/.well-known/mercure
MQ_MERCURE_SUBSCRIBER_TTL_SECONDS=90

