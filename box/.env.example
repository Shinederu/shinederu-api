BASE_URL=https://box.shinederu.lol
AUTH_PORTAL_URL=https://auth.shinederu.lol
AUTH_API_BASE=https://api.shinederu.lol/auth/

DB_TYPE=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=ShinedeCore
DB_USER=authenticator
DB_PASS=change_me

# Optional dedicated DB credentials for this API
MQ_DB_TYPE=
MQ_DB_HOST=
MQ_DB_PORT=
MQ_DB_NAME=
MQ_DB_USER=
MQ_DB_PASS=

UPLOAD_DIR=/var/www/ShinedeBox/uploads
MAX_FILE_MB=20480
ALLOWED_EXT=.zip,.jar,.png,.jpg,.jpeg,.pdf,.rar
ALLOWED_MIME=application/zip,application/x-zip-compressed,application/x-zip,application/java-archive,application/x-java-archive,image/png,image/jpeg,application/pdf,application/vnd.rar,application/x-rar-compressed

